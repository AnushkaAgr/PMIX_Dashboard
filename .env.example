# Copy this file to .env.local and fill in the values

# Secret key for signing JWT tokens — use a long random string
JWT_SECRET=replace-with-a-long-random-secret-key

# Users as JSON object: { "email": "bcrypt_hash" }
# To generate a hash, run:
#   node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
USERS_JSON={"admin@example.com":"$2a$10$REPLACE_WITH_REAL_HASH"}
